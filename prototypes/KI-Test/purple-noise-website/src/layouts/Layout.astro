---
interface Props {
  title: string;
}

const { title } = Astro.props;

import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title} | Purple Noise</title>
    <meta name="title" content={`${title} | Purple Noise - Der Chor für moderne und klassische Chormusik`} />
    <meta name="description" content="Purple Noise - Der Chor für moderne und klassische Chormusik in Berlin. Erlebe einzigartige Chorklänge von Bach bis Pop." />
    <meta name="keywords" content="Chor, Berlin, Chormusik, Singen, Musik, Purple Noise, Kantorei, Kirchenchor" />
    <meta name="author" content="Purple Noise" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.purple-noise.de/" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Preload critical assets -->
    <link rel="preload" as="image" href="/images/logo.png" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.purple-noise.de/" />
    <meta property="og:title" content={`${title} | Purple Noise`} />
    <meta property="og:description" content="Purple Noise - Der Chor für moderne und klassische Chormusik in Berlin." />
    <meta property="og:image" content="/images/jonathangaessler_Pressebilder/2024_03_22_purple_noise_choir_1.jpg" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Purple Noise" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://www.purple-noise.de/" />
    <meta property="twitter:title" content={`${title} | Purple Noise`} />
    <meta property="twitter:description" content="Purple Noise - Der Chor für moderne und klassische Chormusik in Berlin." />
    <meta property="twitter:image" content="/images/jonathangaessler_Pressebilder/2024_03_22_purple_noise_choir_1.jpg" />
    
    <!-- Additional SEO -->
    <meta name="theme-color" content="#7c3aed" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Purple Noise" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
